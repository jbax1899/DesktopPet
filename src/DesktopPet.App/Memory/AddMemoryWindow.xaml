<Window x:Class="DesktopPet.App.Memory.AddMemoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Memory"
        Width="440"
        Height="230"
        MinWidth="360"
        MinHeight="190"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Margin="0,0,0,8"
                   Text="What should the pet remember?" />

        <TextBox x:Name="MemoryTextBox"
                 Grid.Row="1"
                 Padding="8,6"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="2"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button MinWidth="78"
                    Margin="0,0,8,0"
                    Padding="10,4"
                    Click="OnCancelClicked"
                    Content="Cancel"
                    IsCancel="True" />
            <Button MinWidth="78"
                    Padding="10,4"
                    Click="OnAddClicked"
                    Content="Add"
                    IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
