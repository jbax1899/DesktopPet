<UserControl x:Class="DesktopPet.App.Memory.ThumbnailBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="160" Height="90">
    <Grid>
        <Border x:Name="ThumbnailBorder"
                Cursor="Hand"
                ToolTip="Click to expand">
            <Border.Clip>
                <RectangleGeometry Rect="0,0,160,90" />
            </Border.Clip>
            <Image x:Name="ThumbnailImage"
                   Stretch="Uniform" />
        </Border>
        <Popup x:Name="ExpandedPopup"
               AllowsTransparency="True"
               Placement="Right"
               PlacementTarget="{Binding ElementName=ThumbnailBorder}"
               PopupAnimation="Fade"
               StaysOpen="False">
            <Border Margin="8"
                    BorderBrush="#1F2937"
                    BorderThickness="1"
                    CornerRadius="4">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.3" ShadowDepth="4" />
                </Border.Effect>
                <Border.Background>
                    <SolidColorBrush Color="White" />
                </Border.Background>
                <Grid>
                    <Image x:Name="ExpandedImage"
                           MaxWidth="640"
                           MaxHeight="360"
                           Stretch="Uniform" />
                    <TextBlock Margin="8"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               FontSize="11"
                               Foreground="#9CA3AF"
                               Text="Click to close" />
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
