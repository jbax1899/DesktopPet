<Window x:Class="DesktopPet.App.Observation.ObservationMemoryCandidateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Propose Memory"
        Width="560"
        Height="280"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,10"
                   Text="Review and edit this reduced memory. It is saved only when you choose Add memory."
                   TextWrapping="Wrap" />
        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Padding="12,5"
                    Click="OnCancelClicked"
                    Content="Cancel" />
            <Button Margin="8,0,0,0"
                    Padding="12,5"
                    Click="OnAddClicked"
                    Content="Add memory" />
        </StackPanel>
        <TextBox x:Name="CandidateTextBox"
                 AcceptsReturn="True"
                 Padding="8"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
