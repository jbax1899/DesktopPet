<Window x:Class="DesktopPet.App.Memory.MemoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DesktopPet.App.Memory"
        Title="Desktop Pet Memories"
        Width="1080"
        Height="650"
        MinWidth="760"
        MinHeight="480"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <TabControl x:Name="MainTabControl"
                    SelectionChanged="OnTabChanged">
            <TabItem Header="Chat History">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                        <Button x:Name="DeleteChatButton"
                                Style="{StaticResource ActionButton}"
                                Click="OnDeleteChatClicked"
                                Content="Delete"
                                IsEnabled="False" />
                        <Button x:Name="ClearChatButton"
                                Style="{StaticResource ActionButton}"
                                Click="OnClearChatClicked"
                                Content="Clear All"
                                IsEnabled="False" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Margin="0,0,0,6"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="Chat" />
                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Margin="0,0,0,6"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="Details" />

                        <ListBox x:Name="ChatHistoryListBox"
                                 Grid.Row="1"
                                 Grid.Column="0"
                                 BorderBrush="#CBD5E1"
                                 BorderThickness="1"
                                 HorizontalContentAlignment="Stretch"
                                 PreviewMouseLeftButtonDown="OnListBoxPreviewMouseLeftButtonDown"
                                 SelectionChanged="OnChatHistorySelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="10,6">
                                        <Border x:Name="ChatBubble"
                                                MaxWidth="420"
                                                Padding="10,8"
                                                HorizontalAlignment="Left"
                                                Background="#F3F4F6"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock FontSize="13"
                                                           Foreground="#111827"
                                                           Text="{Binding Text}"
                                                           TextWrapping="Wrap" />
                                                <DockPanel Margin="0,6,0,0"
                                                           LastChildFill="False">
                                                    <TextBlock DockPanel.Dock="Left"
                                                               VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Foreground="#6B7280"
                                                               Text="{Binding CreatedAtUtc, StringFormat='{}{0:g} UTC'}" />
                                                    <Button x:Name="DesktopContextButton"
                                                            DockPanel.Dock="Right"
                                                            Width="22"
                                                            Height="22"
                                                            Margin="10,0,0,0"
                                                            Padding="0"
                                                            Click="OnDesktopContextClicked"
                                                            Content="i"
                                                            FontFamily="Segoe UI"
                                                            FontSize="12"
                                                            FontWeight="Bold"
                                                            Foreground="#475569"
                                                            ToolTip="Show desktop context sent to ElevenLabs"
                                                            Visibility="Collapsed">
                                                        <Button.ContextMenu>
                                                            <ContextMenu MaxWidth="460"
                                                                         Padding="12"
                                                                         Placement="Bottom"
                                                                         StaysOpen="False">
                                                                <StackPanel>
                                                                    <TextBlock FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#0F172A"
                                                                               Text="Desktop context sent to ElevenLabs" />
                                                                    <TextBlock Margin="0,3,0,10"
                                                                               FontSize="11"
                                                                               Foreground="#64748B"
                                                                               Text="Reduced, permission-filtered context attached to this reply."
                                                                               TextWrapping="Wrap" />
                                                                    <ItemsControl ItemsSource="{Binding DesktopContextFields}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Margin="0,0,0,7">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="105" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0"
                                                                                               Margin="0,0,10,0"
                                                                                               FontSize="12"
                                                                                               FontWeight="SemiBold"
                                                                                               Foreground="#475569"
                                                                                               Text="{Binding Label}" />
                                                                                    <TextBlock Grid.Column="1"
                                                                                               FontSize="12"
                                                                                               Foreground="#1E293B"
                                                                                               Text="{Binding Value}"
                                                                                               TextWrapping="Wrap" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                    <Button x:Name="PlayAudioButton"
                                                            DockPanel.Dock="Right"
                                                            Width="28"
                                                            Height="22"
                                                            Margin="10,0,0,0"
                                                            Padding="0"
                                                            Click="OnPlayAudioClicked"
                                                            Content="&gt;"
                                                            Tag="{Binding Message}"
                                                            ToolTip="Play cached audio"
                                                            Visibility="Collapsed" />
                                                </DockPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter TargetName="ChatBubble" Property="HorizontalAlignment" Value="Right" />
                                            <Setter TargetName="ChatBubble" Property="Background" Value="#DCFCE7" />
                                            <Setter TargetName="ChatBubble" Property="BorderBrush" Value="#86EFAC" />
                                        </DataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsBot}" Value="True" />
                                                <Condition Binding="{Binding HasAudio}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="PlayAudioButton" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsBot}" Value="True" />
                                                <Condition Binding="{Binding HasDesktopContext}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="DesktopContextButton" Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Column="2"
                                Grid.Row="1"
                                Padding="12"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ContextVariablesItemsControl"
                                              Opacity="0.65">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <local:ContextVariableCard />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Observations">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                        <Button x:Name="DeleteObservationButton"
                                Style="{StaticResource ActionButton}"
                                Click="OnDeleteObservationClicked"
                                Content="Delete"
                                IsEnabled="False" />
                        <Button x:Name="ClearObservationsButton"
                                Style="{StaticResource ActionButton}"
                                Click="OnClearObservationsClicked"
                                Content="Clear All"
                                IsEnabled="False"
                                ToolTip="Clear visual, ambient, and audio observations plus temporary audio transcripts." />
                    </StackPanel>

                    <ListBox x:Name="ObservationsListBox"
                             Grid.Row="1"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             HorizontalContentAlignment="Stretch"
                             PreviewMouseLeftButtonDown="OnListBoxPreviewMouseLeftButtonDown"
                             SelectionChanged="OnObservationSelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,6"
                                        Padding="12,10"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <DockPanel Margin="0,0,0,6">
                                                <TextBlock DockPanel.Dock="Left"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Application}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontSize="11"
                                                           Foreground="#64748B"
                                                           Text="{Binding CapturedAt, StringFormat='{}{0:g}'}" />
                                            </DockPanel>
                                            <TextBlock FontSize="11"
                                                       Foreground="#64748B"
                                                       Text="{Binding Activity}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#334155"
                                                       Text="{Binding Summary}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,5,0,0"
                                                       FontSize="11"
                                                       Foreground="#475569"
                                                       Text="{Binding Excerpt}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding ExcerptVisibility}" />
                                            <StackPanel Margin="0,4,0,0"
                                                        Orientation="Horizontal">
                                                <Ellipse x:Name="OutcomeDot"
                                                         Width="8"
                                                         Height="8"
                                                         Margin="0,0,4,0"
                                                         VerticalAlignment="Center"
                                                         ToolTip="{Binding Outcome}" />
                                                <TextBlock FontSize="11"
                                                           Foreground="#64748B"
                                                           Text="{Binding Status}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <local:ThumbnailBox Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            ThumbnailPath="{Binding ThumbnailPath}"
                                                            VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Outcome}" Value="Spoken">
                                        <Setter TargetName="OutcomeDot" Property="Fill" Value="#22C55E" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Outcome}" Value="BelowThreshold">
                                        <Setter TargetName="OutcomeDot" Property="Fill" Value="#9CA3AF" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Outcome}" Value="Cooldown">
                                        <Setter TargetName="OutcomeDot" Property="Fill" Value="#F59E0B" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Outcome}" Value="Duplicate">
                                        <Setter TargetName="OutcomeDot" Property="Fill" Value="#F97316" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Outcome}" Value="UserBusy">
                                        <Setter TargetName="OutcomeDot" Property="Fill" Value="#3B82F6" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Outcome}" Value="Stale">
                                        <Setter TargetName="OutcomeDot" Property="Fill" Value="#64748B" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Outcome}" Value="Sensitive">
                                        <Setter TargetName="OutcomeDot" Property="Fill" Value="#EF4444" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Outcome}" Value="Recorded">
                                        <Setter TargetName="OutcomeDot" Property="Fill" Value="#14B8A6" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="Memories">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                        <Button Style="{StaticResource ActionButton}"
                                Click="OnAddClicked"
                                Content="Add" />
                        <Button x:Name="DeleteMemoryButton"
                                Style="{StaticResource ActionButton}"
                                Click="OnDeleteMemoryClicked"
                                Content="Delete"
                                IsEnabled="False" />
                        <Button x:Name="ClearMemoriesButton"
                                Style="{StaticResource ActionButton}"
                                Click="OnClearMemoriesClicked"
                                Content="Clear All"
                                IsEnabled="False" />
                    </StackPanel>

                    <ListBox x:Name="MemoryListBox"
                             Grid.Row="1"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             PreviewMouseLeftButtonDown="OnListBoxPreviewMouseLeftButtonDown"
                             SelectionChanged="OnMemorySelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,6">
                                    <StackPanel>
                                        <TextBlock FontSize="13"
                                                   Foreground="#111827"
                                                   Text="{Binding Text}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="#6B7280"
                                                   Text="{Binding CreatedAtUtc, StringFormat='{}{0:g} UTC'}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
