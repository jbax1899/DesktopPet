<Window x:Class="DesktopPet.App.Observation.ObservationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Context Privacy"
        Width="860"
        Height="560"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,12">
            <CheckBox x:Name="ObservationEnabledCheckBox"
                      FontWeight="SemiBold"
                      Content="Enable screen context observation" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#FF475569"
                       Text="Window metadata knows which window is open. Interface labels read visible accessibility text. Visual capture sees the permitted window."
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="#FF9A3412"
                       Text="Visual analysis provider unavailable: visual permission can be saved, but no image will be captured or analyzed."
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center" />
            <Button Padding="12,5"
                    Click="OnRefreshClicked"
                    Content="Refresh apps" />
            <Button Margin="8,0,0,0"
                    Padding="12,5"
                    Click="OnRecentObservationsClicked"
                    Content="Recent observations..." />
            <Button Margin="8,0,0,0"
                    Padding="12,5"
                    Click="OnSaveClicked"
                    Content="Save" />
        </StackPanel>

        <DataGrid x:Name="ApplicationsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding DisplayName}"
                                    Header="Application"
                                    IsReadOnly="True" />
                <DataGridTextColumn Width="3*"
                                    Binding="{Binding ExecutablePath}"
                                    Header="Executable"
                                    IsReadOnly="True" />
                <DataGridCheckBoxColumn Width="75"
                                        Binding="{Binding IsDenied}"
                                        Header="Deny" />
                <DataGridCheckBoxColumn Width="90"
                                        Binding="{Binding AllowMetadata}"
                                        Header="Window" />
                <DataGridCheckBoxColumn Width="95"
                                        Binding="{Binding AllowStructure}"
                                        Header="Labels" />
                <DataGridCheckBoxColumn Width="90"
                                        Binding="{Binding AllowVisual}"
                                        Header="Visual" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
