<Window x:Class="DesktopPet.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Pet Settings"
        Width="460"
        Height="360"
        MinWidth="420"
        MinHeight="340"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="OnWindowPreviewKeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="ElevenLabs API key" />
        <TextBox x:Name="ElevenLabsApiKeyTextBox"
                 Grid.Row="0"
                 Grid.Column="1"
                 Margin="0,0,0,12" />

        <TextBlock Grid.Row="1"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="ElevenLabs Agent ID" />
        <TextBox x:Name="ElevenLabsAgentIdTextBox"
                 Grid.Row="1"
                 Grid.Column="1"
                 Margin="0,0,0,12" />

        <TextBlock Grid.Row="2"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="ElevenLabs voice ID" />
        <TextBox x:Name="ElevenLabsVoiceIdTextBox"
                 Grid.Row="2"
                 Grid.Column="1"
                 Margin="0,0,0,12" />

        <TextBlock Grid.Row="3"
                   Grid.Column="0"
                   Margin="0,0,12,12"
                   VerticalAlignment="Center"
                   Text="Chat shortcut" />
        <StackPanel Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,0,0,12"
                    Orientation="Horizontal">
            <Button x:Name="ChatShortcutButton"
                    MinWidth="130"
                    Padding="10,4"
                    Click="OnRecordShortcutClicked" />
            <Button Margin="8,0,0,0"
                    Padding="10,4"
                    Click="OnResetShortcutClicked"
                    Content="Reset" />
        </StackPanel>

        <StackPanel Grid.Row="5"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="StatusTextBlock"
                       MinWidth="180"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center" />
            <Button Width="90"
                    Padding="10,4"
                    Click="OnSaveClicked"
                    Content="Save" />
        </StackPanel>
    </Grid>
</Window>
