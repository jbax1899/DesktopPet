<Window x:Class="DesktopPet.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Pet Settings"
        Width="620"
        Height="620"
        MinWidth="580"
        MinHeight="460"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="OnWindowPreviewKeyDown">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="StatusTextBlock"
                       MinWidth="180"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center" />
            <Button Width="90"
                    Padding="10,4"
                    Click="OnSaveClicked"
                    Content="Save" />
            <Button Margin="8,0,0,0"
                    Padding="10,4"
                    Click="OnScreenContextClicked"
                    Content="Screen context..." />
        </StackPanel>

        <ScrollViewer Margin="0,0,0,16"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.ColumnSpan="2"
                           Margin="0,0,0,10"
                           FontWeight="SemiBold"
                           Text="ElevenLabs" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,12,12"
                           VerticalAlignment="Center"
                           Text="ElevenLabs API key" />
                <TextBox x:Name="ElevenLabsApiKeyTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,0,12" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,12,12"
                           VerticalAlignment="Center"
                           Text="ElevenLabs Agent ID" />
                <TextBox x:Name="ElevenLabsAgentIdTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,0,0,12" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Margin="0,0,12,18"
                           VerticalAlignment="Center"
                           Text="Preferred voice ID" />
                <TextBox x:Name="ElevenLabsVoiceIdTextBox"
                         Grid.Row="3"
                         Grid.Column="1"
                         Margin="0,0,0,18" />

                <TextBlock Grid.Row="4"
                           Grid.ColumnSpan="2"
                           Margin="0,0,0,10"
                           FontWeight="SemiBold"
                           Text="Profile" />

                <TextBlock Grid.Row="5"
                           Grid.Column="0"
                           Margin="0,0,12,12"
                           VerticalAlignment="Center"
                           Text="Your name" />
                <TextBox x:Name="UserNameTextBox"
                         Grid.Row="5"
                         Grid.Column="1"
                         Margin="0,0,0,12" />

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Margin="0,0,12,12"
                           VerticalAlignment="Center"
                           Text="Nickname" />
                <TextBox x:Name="NicknameTextBox"
                         Grid.Row="6"
                         Grid.Column="1"
                         Margin="0,0,0,12" />

                <TextBlock Grid.Row="7"
                           Grid.ColumnSpan="2"
                           Margin="0,0,0,10"
                           FontWeight="SemiBold"
                           Text="Input" />

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           Text="Chat shortcut" />
                <StackPanel Grid.Row="8"
                            Grid.Column="1"
                            Orientation="Horizontal">
                    <Button x:Name="ChatShortcutButton"
                            MinWidth="130"
                            Padding="10,4"
                            Click="OnRecordShortcutClicked" />
                    <Button Margin="8,0,0,0"
                            Padding="10,4"
                            Click="OnResetShortcutClicked"
                            Content="Reset" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
