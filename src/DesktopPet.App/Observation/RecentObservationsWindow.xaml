<Window x:Class="DesktopPet.App.Observation.RecentObservationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recent Screen Observations"
        Width="700"
        Height="440"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Padding="12,5"
                    Click="OnRefreshClicked"
                    Content="Refresh" />
            <Button Margin="8,0,0,0"
                    Padding="12,5"
                    Click="OnProposeMemoryClicked"
                    Content="Propose memory..." />
        </StackPanel>
        <ListBox x:Name="ObservationsList">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding ApplicationName}" />
                        <TextBlock Foreground="#FF475569"
                                   Text="{Binding ActivityDescription}"
                                   TextWrapping="Wrap" />
                        <TextBlock FontSize="11"
                                   Foreground="#FF64748B"
                                   Text="{Binding ObservedAt}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
