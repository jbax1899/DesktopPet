<Window x:Class="DesktopPet.App.Observation.ObservationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Context Privacy"
        Width="860"
        Height="560"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,12">
            <CheckBox x:Name="ObservationEnabledCheckBox"
                      FontWeight="SemiBold"
                      Content="Enable screen context observation"
                      ToolTip="Master switch for screen context. Saved application permissions remain unchanged." />
            <CheckBox x:Name="AmbientCommentsEnabledCheckBox"
                      Margin="0,6,0,0"
                      Content="Allow ambient comments"
                      ToolTip="Let the pet occasionally comment on meaningful changes in permitted applications." />
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="Commentary" />
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Orientation="Vertical">
                    <UniformGrid Columns="3">
                        <RadioButton x:Name="CommentaryQuietRadioButton"
                                     GroupName="Commentary"
                                     Margin="0,0,4,0"
                                     Content="Quiet"
                                     ToolTip="Rare comments (~15 min cooldown)."
                                     Checked="OnCommentaryLevelChanged" />
                        <RadioButton x:Name="CommentaryBalancedRadioButton"
                                     GroupName="Commentary"
                                     Margin="4,0"
                                     Content="Balanced"
                                     IsChecked="True"
                                     ToolTip="Moderate cadence (~7 min cooldown)."
                                     Checked="OnCommentaryLevelChanged" />
                        <RadioButton x:Name="CommentaryTalkativeRadioButton"
                                     GroupName="Commentary"
                                     Margin="4,0,0,0"
                                     Content="Talkative"
                                     ToolTip="Frequent comments (~3 min cooldown)."
                                     Checked="OnCommentaryLevelChanged" />
                    </UniformGrid>
                    <TextBlock x:Name="CommentaryLegendTextBlock"
                               Margin="2,4,0,0"
                               Foreground="#FF64748B"
                               FontSize="10"
                               Text="How often Pebble speaks when interesting things are found." />
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Margin="0,8,12,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="Vision sensitivity" />
                <StackPanel Grid.Row="1" Grid.Column="1"
                            Orientation="Vertical">
                    <UniformGrid Columns="3">
                        <RadioButton x:Name="VisionLowRadioButton"
                                     GroupName="VisionSensitivity"
                                     Margin="0,0,4,0"
                                     Content="Low"
                                     ToolTip="Only highly interesting changes trigger analysis."
                                     Checked="OnVisionSensitivityChanged" />
                        <RadioButton x:Name="VisionMediumRadioButton"
                                     GroupName="VisionSensitivity"
                                     Margin="4,0"
                                     Content="Medium"
                                     IsChecked="True"
                                     ToolTip="Balanced interest threshold."
                                     Checked="OnVisionSensitivityChanged" />
                        <RadioButton x:Name="VisionHighRadioButton"
                                     GroupName="VisionSensitivity"
                                     Margin="4,0,0,0"
                                     Content="High"
                                     ToolTip="More things trigger analysis, including subtle changes."
                                     Checked="OnVisionSensitivityChanged" />
                    </UniformGrid>
                    <TextBlock x:Name="VisionSensitivityLegendTextBlock"
                               Margin="2,4,0,0"
                               Foreground="#FF64748B"
                               FontSize="10"
                               Text="How easily the vision model considers something interesting to analyze." />
                </StackPanel>
            </Grid>
            <TextBlock Margin="0,6,0,0"
                       Foreground="#FF475569"
                       Text="Metadata identifies the active window and reads visible accessibility labels. Vision sees the permitted window."
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="#FF9A3412"
                       Text="Vision analysis provider unavailable: vision permission can be saved, but no image will be captured or analyzed."
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center" />
            <Button Padding="12,5"
                    Click="OnRefreshClicked"
                    Content="Refresh"
                    ToolTip="Reload saved permissions and rescan visible applications. Unsaved changes are discarded." />
            <Button Margin="8,0,0,0"
                    Padding="12,5"
                    Click="OnSaveClicked"
                    Content="Save"
                    ToolTip="Save screen-context controls and application permissions." />
        </StackPanel>

        <DataGrid x:Name="ApplicationsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding DisplayName}"
                                    IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Application"
                                   ToolTip="Running or previously configured application." />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Width="3*"
                                    Binding="{Binding ExecutablePath}"
                                    IsReadOnly="True">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="Executable"
                                   ToolTip="Executable path used to identify the application." />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="75"
                                        CanUserSort="False">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Deny"
                                   ToolTip="Block all screen context for this application." />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsDenied, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="Block all screen context for this application." />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="100"
                                        CanUserSort="False">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Metadata"
                                   ToolTip="Allow window details, visible accessibility labels, and focused controls." />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding AllowMetadataAndStructure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="Allow window details, visible accessibility labels, and focused controls." />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="90"
                                        CanUserSort="False">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="Vision"
                                   ToolTip="Allow in-memory window capture when vision analysis is available. Also enables Metadata." />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding AllowVisual, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ToolTip="Allow in-memory window capture when vision analysis is available. Also enables Metadata." />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
