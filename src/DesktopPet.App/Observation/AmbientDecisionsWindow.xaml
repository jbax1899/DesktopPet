<Window x:Class="DesktopPet.App.Observation.AmbientDecisionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ambient Comment Decisions"
        Width="760"
        Height="460"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Padding="12,5"
                    Click="OnRefreshClicked"
                    Content="Refresh" />
            <Button Margin="8,0,0,0"
                    Padding="12,5"
                    Click="OnClearClicked"
                    Content="Clear" />
            <Button Margin="8,0,0,0"
                    Padding="12,5"
                    Click="OnProposeMemoryClicked"
                    Content="Propose memory..." />
        </StackPanel>
        <ListBox x:Name="DecisionsList">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding Observation}"
                                   TextWrapping="Wrap" />
                        <TextBlock Foreground="#FF475569">
                            <Run Text="{Binding Reason}" />
                            <Run Text=" — " />
                            <Run Text="{Binding Spoke, StringFormat=Spoke: {0}}" />
                        </TextBlock>
                        <TextBlock FontSize="11"
                                   Foreground="#FF64748B"
                                   Text="{Binding CreatedAt}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
