<Window x:Class="DesktopPet.App.Memory.MemoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DesktopPet.App.Memory"
        Title="Desktop Pet Memories"
        Width="620"
        Height="520"
        MinWidth="500"
        MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <TabControl x:Name="MainTabControl"
                    SelectionChanged="OnTabChanged">
            <TabItem Header="Chat History">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="ChatHistoryListBox"
                             Grid.Row="0"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch" />
                                <Setter Property="Padding"
                                        Value="0" />
                                <Setter Property="BorderThickness"
                                        Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,6">
                                    <Border x:Name="ChatBubble"
                                            MaxWidth="420"
                                            Padding="10,8"
                                            HorizontalAlignment="Left"
                                            Background="#F3F4F6"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <TextBlock FontSize="13"
                                                       Foreground="#111827"
                                                       Text="{Binding Text}"
                                                       TextWrapping="Wrap" />
                                            <DockPanel Margin="0,6,0,0"
                                                       LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           Foreground="#6B7280"
                                                           Text="{Binding CreatedAtUtc, StringFormat='{}{0:g} UTC'}" />
                                                <Button x:Name="PlayAudioButton"
                                                        DockPanel.Dock="Right"
                                                        Width="28"
                                                        Height="22"
                                                        Margin="10,0,0,0"
                                                        Padding="0"
                                                        Click="OnPlayAudioClicked"
                                                        Content="&gt;"
                                                        Tag="{Binding Message}"
                                                        ToolTip="Play cached audio"
                                                        Visibility="Collapsed" />
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}"
                                                 Value="True">
                                        <Setter TargetName="ChatBubble"
                                                Property="HorizontalAlignment"
                                                Value="Right" />
                                        <Setter TargetName="ChatBubble"
                                                Property="Background"
                                                Value="#DCFCE7" />
                                        <Setter TargetName="ChatBubble"
                                                Property="BorderBrush"
                                                Value="#86EFAC" />
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBot}"
                                                       Value="True" />
                                            <Condition Binding="{Binding HasAudio}"
                                                       Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="PlayAudioButton"
                                                Property="Visibility"
                                                Value="Visible" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1"
                          Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="ChatStatusTextBlock"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="#374151"
                                   TextWrapping="Wrap" />
                        <Button Grid.Column="1"
                                MinWidth="78"
                                Padding="10,4"
                                Click="OnRefreshChatClicked"
                                Content="Refresh" />
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Memories">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="NewMemoryTextBox"
                                 Grid.Column="0"
                                 MinHeight="34"
                                 Margin="0,0,8,0"
                                 Padding="8,5"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                        <Button Grid.Column="1"
                                MinWidth="78"
                                Padding="10,4"
                                Click="OnAddClicked"
                                Content="Add" />
                    </Grid>

                    <ListBox x:Name="MemoryListBox"
                             Grid.Row="1"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             SelectionChanged="OnMemorySelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,6">
                                    <StackPanel>
                                        <TextBlock FontSize="13"
                                                   Foreground="#111827"
                                                   Text="{Binding Text}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="11"
                                                   Foreground="#6B7280"
                                                   Text="{Binding CreatedAtUtc, StringFormat='{}{0:g} UTC'}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="2"
                          Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="MemoryStatusTextBlock"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="#374151"
                                   TextWrapping="Wrap" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button MinWidth="78"
                                    Margin="0,0,8,0"
                                    Padding="10,4"
                                    Click="OnRefreshClicked"
                                    Content="Refresh" />
                            <Button x:Name="DeleteMemoryButton"
                                    MinWidth="78"
                                    Margin="0,0,8,0"
                                    Padding="10,4"
                                    Click="OnDeleteClicked"
                                    Content="Delete"
                                    IsEnabled="False" />
                            <Button x:Name="ClearMemoriesButton"
                                    MinWidth="78"
                                    Padding="10,4"
                                    Click="OnClearClicked"
                                    Content="Clear all"
                                    IsEnabled="False" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Observations">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="ObservationsListBox"
                             Grid.Row="0"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment"
                                        Value="Stretch" />
                                <Setter Property="Padding"
                                        Value="0" />
                                <Setter Property="BorderThickness"
                                        Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="8,6"
                                        Padding="12,10"
                                        Background="#F8FAFC"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Application}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontSize="11"
                                                           Foreground="#64748B"
                                                           Text="{Binding WindowTitle}" />
                                            </DockPanel>

                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#334155"
                                                       Text="{Binding Analysis.Summary}"
                                                       TextWrapping="Wrap" />

                                            <StackPanel Margin="0,4,0,0"
                                                        Orientation="Horizontal">
                                                <TextBlock FontSize="11"
                                                           Foreground="#64748B">
                                                    <Run Text="Outcome: " />
                                                    <Run Text="{Binding Outcome}" />
                                                </TextBlock>
                                                <TextBlock x:Name="SpokenAtText"
                                                           Margin="8,0,0,0"
                                                           FontSize="11"
                                                           Foreground="#64748B"
                                                           Visibility="Collapsed">
                                                    <Run Text="Spoken: " />
                                                    <Run Text="{Binding SpokenAt, StringFormat={}{0:g}}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <local:ThumbnailBox Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            ThumbnailPath="{Binding ThumbnailPath}"
                                                            VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1"
                          Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ObservationsStatusTextBlock"
                                   Grid.Column="0"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="#374151"
                                   TextWrapping="Wrap" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Padding="10,4"
                                    Click="OnRefreshObservationsClicked"
                                    Content="Refresh"
                                    ToolTip="Refresh observation history." />
                            <Button Margin="8,0,0,0"
                                    Padding="10,4"
                                    Click="OnClearObservationsClicked"
                                    Content="Clear all"
                                    ToolTip="Clear all observation records." />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
