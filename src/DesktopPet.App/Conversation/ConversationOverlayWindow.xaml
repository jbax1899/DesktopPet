<Window x:Class="DesktopPet.App.Conversation.ConversationOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Pet Conversation"
        Width="800"
        Height="600"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        SourceInitialized="OnSourceInitialized"
        SizeChanged="OnWindowSizeChanged">
    <Canvas x:Name="OverlayCanvas"
            Background="Transparent">
        <Border x:Name="TranscriptShell"
                MinWidth="220"
                MaxWidth="1120"
                MaxHeight="220"
                Padding="22,12,14,12"
                BorderThickness="0"
                CornerRadius="18"
                RenderOptions.ClearTypeHint="Enabled"
                SnapsToDevicePixels="True"
                Visibility="Collapsed">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.46"
                                     GradientOrigin="0.5,0.46"
                                     RadiusX="0.64"
                                     RadiusY="1.15">
                    <GradientStop Color="#D8F8FAFC" Offset="0" />
                    <GradientStop Color="#A8E5E7EB" Offset="0.52" />
                    <GradientStop Color="#44CBD5E1" Offset="0.82" />
                    <GradientStop Color="#00CBD5E1" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="30"
                                  Color="#FF111827"
                                  Opacity="0.10"
                                  ShadowDepth="1" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TranscriptTextBlock"
                           Grid.Column="0"
                           FontFamily="Segoe UI"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1E8F55"
                           LineHeight="24"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <Button x:Name="StopSpeechButton"
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        Margin="10,0,0,0"
                        Padding="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#18FFFFFF"
                        BorderBrush="#301E8F55"
                        BorderThickness="1"
                        Click="OnStopSpeechClicked"
                        Content="■"
                        Cursor="Hand"
                        FontSize="10"
                        Foreground="#CC1E8F55"
                        ToolTip="Stop speaking"
                        Visibility="Collapsed" />
            </Grid>
        </Border>

        <Border x:Name="ErrorShell"
                MaxWidth="520"
                Padding="10,6"
                Background="#CCFEF2F2"
                BorderBrush="#FFFCA5A5"
                BorderThickness="1"
                CornerRadius="8"
                IsHitTestVisible="False"
                Visibility="Collapsed">
            <TextBlock x:Name="ErrorTextBlock"
                       FontFamily="Segoe UI"
                       FontSize="13"
                       Foreground="#FF7F1D1D"
                       TextWrapping="Wrap" />
        </Border>

        <Border x:Name="InputShell"
                MinWidth="260"
                MaxWidth="1120"
                MaxHeight="144"
                Padding="18,10"
                BorderThickness="0"
                CornerRadius="24"
                IsHitTestVisible="True"
                RenderOptions.ClearTypeHint="Enabled"
                SnapsToDevicePixels="True">
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.48"
                                     GradientOrigin="0.42,0.42"
                                     RadiusX="0.7"
                                     RadiusY="1.2">
                    <GradientStop Color="#E6F8FAFC" Offset="0" />
                    <GradientStop Color="#BADDE2E8" Offset="0.5" />
                    <GradientStop Color="#5EBAC2CC" Offset="0.82" />
                    <GradientStop Color="#00BAC2CC" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="34"
                                  Color="#FF111827"
                                  Opacity="0.09"
                                  ShadowDepth="1" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox"
                         Grid.Column="0"
                         MinWidth="160"
                         MaxHeight="112"
                         AcceptsReturn="True"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Segoe UI"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="#FF0F172A"
                         Padding="2,1"
                         PreviewKeyDown="OnInputPreviewKeyDown"
                         PreviewTextInput="OnInputPreviewTextInput"
                         SpellCheck.IsEnabled="True"
                         TextChanged="OnInputTextChanged"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto">
                </TextBox>

                <StackPanel x:Name="PendingSpinner"
                      Grid.Column="1"
                      Width="38"
                      Height="18"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Orientation="Horizontal"
                      Visibility="Collapsed">
                    <Ellipse Width="6"
                             Height="6"
                             Margin="3,0"
                             Fill="#E61F2937">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.25"
                                                         To="1"
                                                         AutoReverse="True"
                                                         Duration="0:0:0.52"
                                                         RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="6"
                             Height="6"
                             Margin="3,0"
                             Fill="#E61F2937">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.16">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.25"
                                                         To="1"
                                                         AutoReverse="True"
                                                         Duration="0:0:0.52"
                                                         RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="6"
                             Height="6"
                             Margin="3,0"
                             Fill="#E61F2937">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard BeginTime="0:0:0.32">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.25"
                                                         To="1"
                                                         AutoReverse="True"
                                                         Duration="0:0:0.52"
                                                         RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </StackPanel>
            </Grid>
        </Border>
    </Canvas>
</Window>
