<Window x:Class="DesktopPet.App.Memory.MemoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Pet Memories"
        Width="540"
        Height="440"
        MinWidth="460"
        MinHeight="360"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="NewMemoryTextBox"
                     Grid.Column="0"
                     MinHeight="34"
                     Margin="0,0,8,0"
                     Padding="8,5"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
            <Button Grid.Column="1"
                    MinWidth="78"
                    Padding="10,4"
                    Click="OnAddClicked"
                    Content="Add" />
        </Grid>

        <ListBox x:Name="MemoryListBox"
                 Grid.Row="1"
                 BorderBrush="#CBD5E1"
                 BorderThickness="1"
                 SelectionChanged="OnMemorySelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="4,6">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="#111827"
                                       Text="{Binding Text}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="11"
                                       Foreground="#6B7280"
                                       Text="{Binding CreatedAtUtc, StringFormat='{}{0:g} UTC'}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2"
              Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Column="0"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Foreground="#374151"
                       TextWrapping="Wrap" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button MinWidth="78"
                        Margin="0,0,8,0"
                        Padding="10,4"
                        Click="OnRefreshClicked"
                        Content="Refresh" />
                <Button x:Name="DeleteMemoryButton"
                        MinWidth="78"
                        Margin="0,0,8,0"
                        Padding="10,4"
                        Click="OnDeleteClicked"
                        Content="Delete"
                        IsEnabled="False" />
                <Button x:Name="ClearMemoriesButton"
                        MinWidth="78"
                        Padding="10,4"
                        Click="OnClearClicked"
                        Content="Clear all"
                        IsEnabled="False" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
