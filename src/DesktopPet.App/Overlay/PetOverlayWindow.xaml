        <Style x:Key="ActionPadButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#6B7280" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="Foreground" Value="#9CA3AF" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF2F7" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E5E7EB" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid MouseLeftButtonDown="OnOverlayMouseLeftButtonDown"
          PreviewMouseRightButtonDown="OnOverlayPreviewMouseRightButtonDown"
          MouseRightButtonUp="OnOverlayMouseRightButtonUp">
        <Viewbox x:Name="PuppetHost"
                 Stretch="Uniform" />

        <Border x:Name="ActionPad"
                Width="166"
                Padding="6"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,48,0,0"
                Background="#F3F4F6"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="8"
                RenderOptions.ClearTypeHint="Enabled"
                SnapsToDevicePixels="True"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ActionPadButtonStyle}"
                        Click="OnChatActionClicked"
                        ToolTip="Chat">
                    <Viewbox Width="24"
                             Height="24">
                        <Path Data="{StaticResource ChatTextIconGeometry}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                              Stretch="Uniform" />
                    </Viewbox>
                </Button>

                <Button IsEnabled="False"
                        Style="{StaticResource ActionPadButtonStyle}"
                        ToolTip="Voice input coming later">
                    <Viewbox Width="24"
                             Height="24">
                        <Path Data="{StaticResource MicrophoneIconGeometry}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                              Stretch="Uniform" />
                    </Viewbox>
                </Button>

                <Button Style="{StaticResource ActionPadButtonStyle}"
                        Click="OnSettingsActionClicked"
                        ToolTip="Settings">
                    <Viewbox Width="24"
                             Height="24">
                        <Path Data="{StaticResource GearSixIconGeometry}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                              Stretch="Uniform" />
                    </Viewbox>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
