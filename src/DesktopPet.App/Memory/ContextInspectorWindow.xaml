<Window x:Class="DesktopPet.App.Memory.ContextInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DesktopPet.App.Memory"
        Title="Agent Context Inspector"
        Width="680"
        Height="620"
        MinWidth="520"
        MinHeight="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <TabControl>
            <TabItem Header="Next request">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right"
                                Padding="10,4"
                                Click="OnRefreshLivePreviewClicked"
                                Content="Refresh" />
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Context that would be attached to the next Agent request" />
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="0,0,0,10"
                            Padding="10,8"
                            Background="#FFF8E1"
                            BorderBrush="#F6C453"
                            BorderThickness="1"
                            CornerRadius="6">
                        <TextBlock Foreground="#6B4F00"
                                   Text="Desktop context is collected only when a message is submitted. This preview does not inspect the foreground app, capture a screenshot, or call a provider."
                                   TextWrapping="Wrap" />
                    </Border>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LiveVariables}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <local:ContextVariableCard />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Selected reply">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,10"
                               Foreground="#475569"
                               Text="{Binding HistoricalStatus}"
                               TextWrapping="Wrap" />

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding HistoricalVariables}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <local:ContextVariableCard />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
