<Window x:Class="DesktopPet.App.Settings.PronunciationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom Pronunciations"
        Width="560"
        Height="430"
        MinWidth="500"
        MinHeight="340"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,14,0,0">
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,0,0,8"
                       Foreground="#FF475569"
                       TextWrapping="Wrap" />
            <StackPanel HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button Width="90"
                        Margin="0,0,8,0"
                        Padding="10,4"
                        Click="OnCancelClicked"
                        Content="Cancel" />
                <Button x:Name="SaveButton"
                        Width="90"
                        Padding="10,4"
                        Click="OnSaveClicked"
                        Content="Save" />
            </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,12">
            <TextBlock FontSize="17"
                       FontWeight="SemiBold"
                       Text="Custom pronunciations" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="#FF64748B"
                       Text="Tell Pebble how names, acronyms, or unusual words should sound."
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,8,4"
                           Foreground="#FF475569"
                           Text="Word or phrase" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,0,8,4"
                           Foreground="#FF475569"
                           Text="Pronounce it like" />
                <TextBox x:Name="TextTextBox"
                         Grid.Row="1"
                         Grid.Column="0"
                         Margin="0,0,8,0"
                         Padding="6,4"
                         ToolTip="Word or phrase, for example: Pebble" />
                <TextBox x:Name="AliasTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,8,0"
                         Padding="6,4"
                         ToolTip="How it should sound, for example: peh-bull" />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        MinWidth="70"
                        Padding="10,4"
                        Click="OnAddClicked"
                        Content="Add" />
            </Grid>

            <DataGrid x:Name="PronunciationsGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      ItemsSource="{Binding Pronunciations}"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*"
                                        Header="Word or phrase"
                                        Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Width="*"
                                        Header="Pronounce it like"
                                        Binding="{Binding Alias, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTemplateColumn Width="76">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Padding="6,2"
                                        Click="OnRemoveClicked"
                                        Content="Remove"
                                        Tag="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
